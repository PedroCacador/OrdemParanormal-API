  "item": [
    {
      "name": "Agents",
      "description": "Endpoints para gerenciamento de agentes",
      "item": [
        {
          "name": "GetAll Agents",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/agents",
              "host": ["{{base_url}}"],
              "path": ["agents"]
            },
            "description": "Retorna todos os agentes cadastrados."
          }
        },
        {
          "name": "Get agent by id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/agents/:id",
              "host": ["{{base_url}}"],
              "path": ["agents", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            },
            "description": "Retorna um agente pelo ID."
          }
        },
        {
          "name": "Create a new agent",
          "request": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Karen\",\n  \"codename\": \"Caveira\",\n  \"level\": \"recruit\",\n  \"specialty\": \"combatant\",\n  \"status\": \"active\",\n  \"teamId\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/agents",
              "host": ["{{base_url}}"],
              "path": ["agents"]
            },
            "description": "Cria um novo agente."
          }
        },
        {
          "name": "Update agent",
          "request": {
            "method": "PUT",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Karen\",\n  \"codename\": \"Caveira\",\n  \"level\": \"veteran\",\n  \"specialty\": \"combatant\",\n  \"status\": \"active\",\n  \"teamId\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/agents/:id",
              "host": ["{{base_url}}"],
              "path": ["agents", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            },
            "description": "Atualiza completamente um agente."
          }
        },
        {
          "name": "Patch agent",
          "request": {
            "method": "PATCH",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"inactive\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/agents/:id",
              "host": ["{{base_url}}"],
              "path": ["agents", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            },
            "description": "Atualiza parcialmente um agente."
          }
        },
        {
          "name": "Delete agent",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/agents/:id",
              "host": ["{{base_url}}"],
              "path": ["agents", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            },
            "description": "Remove um agente."
          }
        }
      ]
    },
